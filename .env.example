# Template for .env (copy to .env and fill in). Auto-loaded by the control
# plane (dotenvy) and the MCP server (python-dotenv). .env itself is gitignored.
#
# This lists every setting the harness reads. Locally you only need the tokens,
# a store, and an artifacts backend; the rest are for the Fly deployment.

# --- shared tokens -----------------------------------------------------------
# Generate: openssl rand -hex 24. Must match whatever control plane you target
# (local or the Fly deployment's `fly secrets`).
CHUK_TRAIN_API_TOKEN=
CHUK_TRAIN_JOIN_TOKEN=

# --- MCP client --------------------------------------------------------------
# The control plane the tools talk to. Fly: https://<app>.fly.dev
# Local: http://127.0.0.1:8700
CHUK_TRAIN_URL=http://127.0.0.1:8700

# --- metadata store (adapter seam) -------------------------------------------
# Neon (serverless Postgres) in production — use the POOLED endpoint:
#   CHUK_TRAIN_STORE=postgresql://<user>:<pass>@ep-xxxx-pooler.<region>.aws.neon.tech/<db>?sslmode=require
# Local dev can use SQLite instead (a bare path also means SQLite):
CHUK_TRAIN_STORE=sqlite:chuk_train.db

# --- artifact blob store (adapter seam) --------------------------------------
# R2 in production (zero egress); a local filesystem path for dev.
#   CHUK_TRAIN_ARTIFACTS=r2://chuk-train
CHUK_TRAIN_ARTIFACTS=file:./chuk_train_artifacts

# --- R2 / S3 credentials (needed when ARTIFACTS is r2://) ---------------------
# R2 endpoint: https://<account-id>.r2.cloudflarestorage.com ; region is "auto".
# Access key / secret are an R2 API token (32 / 64 hex chars).
CHUK_TRAIN_S3_ENDPOINT=
CHUK_TRAIN_S3_REGION=auto
CHUK_TRAIN_S3_ACCESS_KEY_ID=
CHUK_TRAIN_S3_SECRET_ACCESS_KEY=
CHUK_TRAIN_S3_BUCKET=chuk-train

# --- control plane bind + public identity ------------------------------------
CHUK_TRAIN_HOST=127.0.0.1
CHUK_TRAIN_PORT=8700
# Externally reachable base URL (artifact/download URLs are built from it).
CHUK_TRAIN_PUBLIC_URL=https://<app>.fly.dev
# Websocket URL provisioned workers dial back on (wss:// in production).
CHUK_TRAIN_AGENT_WS_URL=wss://<app>.fly.dev/ws/agent

# --- providers + agent binary ------------------------------------------------
CHUK_TRAIN_PROVIDERS=mock
CHUK_TRAIN_AGENT_BIN=./target/x86_64-unknown-linux-musl/release/chuk-train-agent
# CHUK_TRAIN_VAST_API_KEY=

# --- dashboard Google sign-in (usually set as Fly secrets) -------------------
# When client id + secret + an allowlist are all set, the dashboard requires
# Google login and only the allowlisted emails may view it. Unset locally =
# API-token box. Redirect URI: https://<app>.fly.dev/auth/callback.
# CHUK_TRAIN_GOOGLE_CLIENT_ID=
# CHUK_TRAIN_GOOGLE_CLIENT_SECRET=
# CHUK_TRAIN_ALLOWED_EMAILS=you@example.com

# --- Google Drive archive tier (optional cold storage) -----------------------
# Long-lived refresh token (drive.file scope) minted by scripts/authorize-drive.py.
# Refreshed against the client id/secret above. When set, completed runs'
# checkpoints/logs tier from R2 (hot) to Drive (cold).
# CHUK_TRAIN_GOOGLE_REFRESH_TOKEN=

# --- chuk-experiments-server reporting mirror (optional) ---------------------
# When URL + API key are set, the control plane mirrors run lifecycle +
# checkpoints (as artifacts) into chuk-experiments-server, best-effort. Unset =
# off (a no-op); the harness always runs standalone. The key is a WRITE-scoped
# experiments-server API key (raw bearer, NOT a ck_ key). Programme/experiment
# default to gpu-training-harness / harness-runs.
# CHUK_EXPERIMENTS_URL=https://chuk-experiments-server.fly.dev
# CHUK_EXPERIMENTS_API_KEY=
# CHUK_EXPERIMENTS_PROGRAMME=gpu-training-harness
# CHUK_EXPERIMENTS_EXPERIMENT=harness-runs

# --- timings (optional; short values speed local lease tests) ----------------
# CHUK_TRAIN_RECONCILE_S=
# CHUK_TRAIN_IDLE_REAP_S=
# CHUK_TRAIN_DRAIN_WINDOW_MIN=
