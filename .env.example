# Template for .env (copy to .env and fill in). Auto-loaded by the control
# plane (dotenvy) and the MCP server (python-dotenv). .env itself is gitignored.

# --- shared tokens -----------------------------------------------------------
# Generate: openssl rand -hex 24. Must match whatever control plane you target
# (local or the Fly deployment's `fly secrets`).
CHUK_TRAIN_API_TOKEN=
CHUK_TRAIN_JOIN_TOKEN=

# --- MCP client --------------------------------------------------------------
# The control plane the tools talk to. Fly: https://<app>.fly.dev
# Local: http://127.0.0.1:8700
CHUK_TRAIN_URL=http://127.0.0.1:8700

# --- local control plane (running `cargo run -p chuk-train-cp`) --------------
CHUK_TRAIN_STORE=sqlite:chuk_train.db
CHUK_TRAIN_ARTIFACTS=file:./chuk_train_artifacts
CHUK_TRAIN_HOST=127.0.0.1
CHUK_TRAIN_PORT=8700
CHUK_TRAIN_PROVIDERS=mock
CHUK_TRAIN_AGENT_BIN=./target/x86_64-unknown-linux-musl/release/chuk-train-agent
